<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>$(LatestFramework)</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Examples.Logging.Nlog</RootNamespace>
    <UserSecretsId>506191a8-a8c6-4227-bb12-5feafc0b26a1</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.10" />
    <PackageReference Include="NLog" Version="6.1.4" />
    <PackageReference Include="NLog.Extensions.Hosting" Version="6.1.4" />
  </ItemGroup>

  <ItemGroup>
    <None Update="NLog.config" CopyToOutputDirectory="Never" />
  </ItemGroup>

</Project>