{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Async",
      "Serilog.Enrichers.Thread",
      "Serilog.Enrichers.Environment"
    ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": {
      "0": {
        "Name": "Console"
      },
      "1": {
        "Name": "Async",
        "Args": {
          "configure": {
            "0": {
              "Name": "File",
              "Args": {
                "path": "logs/examples.log",
                "rollingInterval": "Day",
                "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.ffffffzzz} [{Level:u4}] {Message:lj} {Properties:j}{NewLine}{Exception}"
              }
            }
          }
        }
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}